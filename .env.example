# Choose backend explicitly.

# Local development calls: /api/... through the Vite proxy.
VITE_API_BACKEND=local

# Production builds default to https://api.trackpal.app/api/... unless VITE_API_BASE_URL is set.
# VITE_API_BACKEND=production

# Optional explicit override:
# VITE_API_BASE_URL=https://api.trackpal.app/api
